                          ],
                          "children": [
                            {
                              "type": "text",
                              "id": "k0gMb",
                              "name": "privacyCard2Text",
                              "fill": "#475569",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "2  通信が発生するケース\nURL ショートカット追加時のみ、指定 URL のタイトルやファビコンを取得するための通信が発生します。\n・ 取得したメタデータは端末内に保存され、外部送信や解析には利用しません。\n・ リダイレクトが発生した場合を除き、通信先は指定 URL のホストのみに限定されます。",
                              "lineHeight": 1.7,
                              "fontFamily": "Outfit",
                              "fontSize": 21,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "frame",
