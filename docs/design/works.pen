                              "fill": "#475569",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "1  収集しないもの\n・ 利用状況や操作ログなどの分析データ\n・ メールアドレスやデバイス ID などの個人を特定できる情報\n・ ショートカット配置やアイコン設定のクラウド送信 / 同期",
                              "lineHeight": 1.7,
                              "fontFamily": "Outfit",
                              "fontSize": 22,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "12Wpt",
                          "name": "privacyCard2",
                          "width": 1336,
                          "fill": "#FFFFFF",
                          "cornerRadius": 28,
                          "stroke": {
                            "align": "inside",
                            "thickness": 1,
                            "fill": "#E2E8F0"
                          },
                          "layout": "vertical",
                          "padding": [
